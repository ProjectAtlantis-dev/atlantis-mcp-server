{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2020", // Target modern Node versions
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    /* Strictness */
    "strict": false, // Turn off strict mode
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": false, // Allow implicit any when strict is false

    /* If NOT transpiling with TypeScript: */
    // "module": "preserve", // Keep imports/exports as-is if using ts-node or another bundler
    // "noEmit": true, // Don't output files if running directly

    /* If your code runs in Node.js, uncomment these options: */
    "module": "CommonJS", // Use CommonJS modules for Node.js compatibility
    "outDir": "./dist", // Output directory for compiled JS files
    "rootDir": "./src", // Specify the root directory of source files (we'll move server.ts here)

    /* Linting */
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
  },
  "include": ["src/**/*"], // Include all files in the src directory
  "exclude": ["node_modules", "dist"] // Exclude build output and dependencies
  // "ts-node": { // Optional: ts-node specific settings
  //   "compilerOptions": {
  //     "module": "CommonJS" // Ensure ts-node uses CommonJS
  //   }
  // }
}
